{% liquid
  assign threshold = settings.cart_booster_shipping_threshold | times: 100
  assign cart_total = cart.total_price
  assign amount_remaining = threshold | minus: cart_total

  if threshold > 0
    assign progress = cart_total | times: 100 | divided_by: threshold
  else
    assign progress = 0
  endif

  if progress > 100
    assign progress = 100
  endif
%}

<div class="cart-drawer-booster">

  <!-- SHIPPING TEXT -->
 <div
  class="cart-drawer-booster"
  data-cart-booster
  data-threshold="{{ threshold }}"
>

  <div class="cart-drawer-booster__shipping">

    {% if amount_remaining > 0 %}
      <p data-cart-booster-message>
        Noch <strong>{{ amount_remaining | money }}</strong> bis zum kostenlosen Versand!
      </p>
    {% else %}
      <p data-cart-booster-message class="success">
        🎉 Glückwunsch! Kostenloser Versand erreicht.
      </p>
    {% endif %}

  </div>

  <div
  class="cart-drawer-booster__progress"
  style="width: 100%; height: 8px; background: #eeeeee; border-radius: 999px; overflow: hidden; margin-top: 8px;"
>
  <div
    data-cart-booster-progress
    style="display: block; width: {{ progress }}%; height: 100%; background: #7c3aed; border-radius: 999px; transition: width 0.3s ease;"
  ></div>
</div>

</div>

</div>