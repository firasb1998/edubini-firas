{%- render 'cart-drawer',
  shipping_threshold: section.settings.shipping_threshold,
  upsell_product: section.settings.upsell_product
-%}

{% schema %}
{
  "name": "Cart Drawer",
  "settings": [
    {
      "type": "number",
      "id": "shipping_threshold",
      "label": "Free shipping threshold",
      "default": 50
    },
    {
      "type": "product",
      "id": "upsell_product",
      "label": "Upsell product"
    }
  ]
}
{% endschema %}